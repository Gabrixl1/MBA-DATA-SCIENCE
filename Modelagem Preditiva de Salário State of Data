    {
      "cell_type": "code",
      "source": [
        "from sklearn.linear_model import LinearRegression\n",
        "from sklearn.tree import DecisionTreeRegressor\n",
        "from sklearn.neighbors import KNeighborsRegressor\n",
        "from sklearn.metrics import mean_absolute_error, r2_score\n",
        "from sklearn.model_selection import train_test_split # Import train_test_split\n",
        "\n",
        "# Perform train-test split using the correctly prepared X and y_regressao\n",
        "X_train, X_test, y_train_reg, y_test_reg = train_test_split(X, y_regressao, test_size=0.2, random_state=42)\n",
        "\n",
        "# 1. Regressão Linear\n",
        "reg_lin = LinearRegression().fit(X_train, y_train_reg)\n",
        "y_pred_lin = reg_lin.predict(X_test)\n",
        "\n",
        "# 2. Árvore de Decisão (Regressão)\n",
        "reg_tree = DecisionTreeRegressor(max_depth=5, random_state=42).fit(X_train, y_train_reg)\n",
        "y_pred_tree_reg = reg_tree.predict(X_test)\n",
        "\n",
        "# 3. KNN (Regressão)\n",
        "reg_knn = KNeighborsRegressor(n_neighbors=10).fit(X_train, y_train_reg)\n",
        "y_pred_knn_reg = reg_knn.predict(X_test)\n",
        "\n",
        "print(\"--- RESULTADOS REGRESSÃO (Erro Médio em R$) ---\")\n",
        "print(f\"Linear Regression: R$ {mean_absolute_error(y_test_reg, y_pred_lin):.2f}\")\n",
        "print(f\"Decision Tree: R$ {mean_absolute_error(y_test_reg, y_pred_tree_reg):.2f}\")\n",
        "print(f\"KNN: R$ {mean_absolute_error(y_test_reg, y_pred_knn_reg):.2f}\")"
