    {
      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "\n",
        "# Carregar o arquivo (use o nome exato do arquivo que você anexou)\n",
        "df = pd.read_csv('/content/Final Dataset - State of Data 2024 - Kaggle - df_survey_2024 (2).csv')\n",
        "\n",
        "# Nomes exatos extraídos do seu arquivo para evitar KeyError:\n",
        "colunas_reais = {\n",
        "    'idade': '1.a_idade',\n",
        "    'escolaridade': '1.l_nivel_de_ensino', # No seu arquivo é 'nivel_de_ensino'\n",
        "    'cargo': '2.f_cargo_atual',           # No seu arquivo é 'cargo_atual'\n",
        "    'nivel': '2.g_nivel',                 # No seu arquivo é '2.g_nivel'\n",
        "    'salario': '2.h_faixa_salarial',\n",
        "    'experiencia_dados': '2.i_tempo_de_experiencia_em_dados'\n",
        "}"
      ],
      "metadata": {
