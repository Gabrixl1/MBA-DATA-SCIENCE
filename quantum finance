        "# ===================== K-MEANS CORRIGIDO =====================\n",
        "\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "from sklearn.cluster import KMeans\n",
        "import numpy as np\n",
        "\n",
        "# 1. Garantir só números\n",
        "X_kmeans = X.select_dtypes(include=[np.number])\n",
        "\n",
        "# 2. Limpar NaN e infinito\n",
        "X_kmeans = X_kmeans.replace([np.inf, -np.inf], np.nan)\n",
        "X_kmeans = X_kmeans.fillna(X_kmeans.mean())\n",
        "\n",
        "# 3. Remover colunas com variância zero\n",
        "X_kmeans = X_kmeans.loc[:, X_kmeans.nunique() > 1]\n",
        "\n",
        "# 4. Escalonar\n",
        "scaler = StandardScaler()\n",
        "X_scaled = scaler.fit_transform(X_kmeans)\n",
        "\n",
        "# 5. KMeans\n",
        "kmeans = KMeans(n_clusters=3, random_state=42, n_init=10)\n",
        "clusters = kmeans.fit_predict(X_scaled)\n",
        "\n",
        "# 6. Adicionar no dataset\n",
        "train['Cluster'] = clusters\n",
        "\n",
        "# 7. Análise\n",
        "cluster_analysis = train.groupby('Cluster').mean()\n",
